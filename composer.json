{
  "name": "dozor/dozor-agent",
  "description": "Self-hostable Laravel instrumentation and local agent starter inspired by laravel/nightwatch.",
  "keywords": ["laravel", "monitoring", "apm", "observability", "dozor"],
  "homepage": "https://example.com/dozor",
  "license": "MIT",
  "authors": [
    {
      "name": "Dozor",
      "email": "engineering@example.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
    "symfony/console": "^6.0|^7.0"
  },
  "autoload": {
    "psr-4": {
      "Dozor\\": "src/"
    },
    "files": [
      "agent/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Dozor\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Dozor\\DozorServiceProvider"
      ],
      "aliases": {
        "Dozor": "Dozor\\Facades\\DozorFacade"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "audit": {
      "block-insecure": false
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  }
}
